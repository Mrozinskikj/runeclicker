{
  "name": "valrune",
  "author": "Krzysztof Mrozinski",
  "description": "Valrune - Incremental RPG",
  "private": true,
  "version": "2.2.0",
  "type": "module",
  "main": "dist/main/index.js",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "dev": "vite",
    "electron:dev": "electron-vite dev --outDir=dist",
    "build": "tsc -b && vite build",
    "build:web": "tsc -b && vite build",
    "build:electron": "electron-vite build --outDir=dist",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron-vite preview --outDir=dist",
    "package": "electron-vite build --outDir=dist && electron-forge package",
    "make": "electron-vite build --outDir=dist && electron-forge make"
  },
  "dependencies": {
    "lz-string": "^1.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.2",
    "@electron-forge/maker-deb": "^7.8.2",
    "@electron-forge/maker-rpm": "^7.8.2",
    "@electron-forge/maker-squirrel": "^7.8.2",
    "@electron-forge/maker-zip": "^7.8.2",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "electron": "^37.2.6",
    "electron-vite": "^4.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "asar": true
      },
      "makers": [
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-squirrel",
          "platforms": [
            "win32"
          ],
          "config": {
            "name": "valrune"
          }
        },
        {
          "name": "@electron-forge/maker-deb",
          "platforms": [
            "linux"
          ]
        },
        {
          "name": "@electron-forge/maker-rpm",
          "platforms": [
            "linux"
          ]
        }
      ]
    }
  }
}